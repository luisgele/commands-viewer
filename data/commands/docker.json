    {
      "id": "docker-002",
      "toolId": "docker",
      "section": "Containers",
      "name": "docker run image",
      "description": "Ejecuta un container desde una imagen",
      "hint": "-d detached · -p 8080:80 puertos · --rm auto-delete",
      "importance": "critical",
      "frequency": 4,
      "tags": ["containers", "run"],
      "notes": "",
      "favorite": false,
      "order": 1,
      "docUrl": "https://docs.docker.com/reference/cli/docker/container/run/",
      "modifiers": [
        { "flag": "-d", "description": "Detached mode — corre en background" },
        { "flag": "-p host:container", "description": "Publica puerto en el host", "example": "-p 8080:80" },
        { "flag": "-v host:container", "description": "Monta volumen", "example": "-v ./data:/app/data" },
        { "flag": "--rm", "description": "Elimina container al terminar" },
        { "flag": "--name label", "description": "Nombre legible para el container" },
        { "flag": "-e KEY=value", "description": "Variable de entorno" },
        { "flag": "--network mynet", "description": "Conecta a red Docker específica" },
        { "flag": "-it", "description": "Interactive + TTY (shells)" },
        { "flag": "--restart unless-stopped", "description": "Política de reinicio" }
      ]
    },
    {
      "id": "docker-003",
      "toolId": "docker",
      "section": "Containers",
      "name": "docker exec -it id bash",
      "description": "Entra en un container en ejecución",
      "hint": "sh si no hay bash",
      "importance": "high",
      "frequency": 4,
      "tags": ["containers", "debug"],
      "notes": "",
      "favorite": false,
      "order": 2,
      "docUrl": "https://docs.docker.com/reference/cli/docker/container/exec/",
      "modifiers": [
        { "flag": "-it", "description": "Interactive + TTY (esencial para shells)" },
        { "flag": "-u root", "description": "Ejecuta como otro usuario" },
        { "flag": "-w /path", "description": "Working directory dentro del container" },
        { "flag": "-e VAR=val", "description": "Define variable de entorno" }
      ]
    },
